MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 5971298429432631055}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7c74432ea036acc428c5688b3a06ac49, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _dialogues:
  - _phrases:
    - "Ohh no!\r\n\nMy delicious <b>beer</b> is missing!\n \r\nWithout I can\u2019t
      enjoy my meal. \r\n\n"
  - _phrases:
    - "Thanks for the beer!\r\n\nI'll give you this sausage in exchange. \r\n\nMaybe
      someone is <b>hungry</b>? \r\n"
    - "<b>Fun Fact</b>\r\n\nIn Mary Shelley's novel Frankenstein, Victor Frankenstein
      \nstudied and created his famous creature in Ingolstadt. \n\nMaking the city
      the birthplace \nof the legendary monster."
