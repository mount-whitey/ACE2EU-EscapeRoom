  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 7c74432ea036acc428c5688b3a06ac49, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  _dialogues:
  - _phrases:
    - The door is locked - <b><u>no</u></b> escape!
  - _phrases:
    - 'A mysterious clicking sound

      echoes through the room!'
  - _phrases:
    - "<b>Finally!</b>\n\nA hidden mechanism clicks \ninto place. The door opens.
      \r    \n\n<b>- time to escape -"
  - _phrases:
    - 'There is something  <b><u>missing</u></b>!


      But I don''t know what...


      By
      the way - the lion has

      a really big head.'
